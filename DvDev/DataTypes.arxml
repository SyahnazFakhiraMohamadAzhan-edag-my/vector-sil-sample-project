              <DESC>
                <L-2 L="FOR-ALL">sint8_least represents a signed integer with values defined by at least 8 bit.</L-2>
              </DESC>
              <CATEGORY>VALUE</CATEGORY>
              <ADMIN-DATA>
                <SDGS>
                  <SDG GID="DV_SDG">
                    <SD GID="DV_ReadOnly">1</SD>
                  </SDG>
                </SDGS>
